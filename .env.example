# Server
PORT=3010

# Runtime data directory (tokens, cache, OAuth state — gitignored)
MAIL_DATA_DIR=./data

# When true, POST /api/outlook/send|read and DELETE /api/outlook/config require X-AIOS-Approval-Id
MAIL_REQUIRE_APPROVAL=false
# Shared secret for AIOSv2 proxy → standalone (optional)
MAIL_INTERNAL_API_KEY=

# Microsoft Graph / OAuth (delegated)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OUTLOOK_MAILBOX_USER=

# AI Providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=f-aios-v3
FAIOS_SERVER_URL=http://localhost:3201
LMSTUDIO_MODEL=qwen/qwen3.5-9b
LMSTUDIO_URL=http://localhost:1234

# AIOS integration
MAIL_INTELLIGENCE_URL=http://localhost:3010
AIOS_APPROVAL_DEV_BYPASS=true

# Graph sync tuning
MAIL_GRAPH_PAGE_SIZE=100
MAIL_GRAPH_MAX_PAGES=20
MAIL_AI_ANALYSIS_LIMIT=3
MAIL_AI_THREAD_GROUP_LIMIT=24
