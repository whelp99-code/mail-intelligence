{
  "name": "standalone-mail-intelligence",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=3010 node server.mjs",
    "start": "PORT=3010 node server.mjs",
    "check": "node --check server.mjs && node --check src/app.js && node --check src/analyzer.js",
    "verify:health": "node scripts/verify-health.mjs",
    "verify:health:full": "node scripts/verify-health.mjs --full",
    "verify:threads": "node scripts/verify-thread-grouping.mjs",
    "verify:boundary": "node scripts/verify-mail-readonly-boundary.mjs",
    "verify:attachments": "node scripts/verify-attachment-sync.mjs",
    "verify:entities": "node scripts/verify-entity-resolution.mjs",
    "migrate:data": "node scripts/migrate-data-dir.mjs",
    "lint": "eslint server.mjs src/app.js src/analyzer.js --ext .js,.mjs",
    "lint:fix": "eslint server.mjs src/app.js src/analyzer.js --ext .js,.mjs --fix",
    "validate:html": "htmlhint src/index.html",
    "validate:css": "stylelint src/styles.css",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "htmlhint": "^1.1.4",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}